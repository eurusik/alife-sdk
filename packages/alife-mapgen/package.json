{
  "name": "@alife-sdk/mapgen",
  "version": "0.1.0",
  "description": "Procedural top-down map generator for the A-Life SDK — framework-agnostic, outputs MapDefinition consumed by Phaser or any renderer adapter",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "alife",
    "mapgen",
    "procedural",
    "tilemap",
    "autotile",
    "pathfinding"
  ],
  "license": "MIT",
  "author": "Eugene Rusakov",
  "repository": {
    "type": "git",
    "url": "https://github.com/eurusik/alife-sdk.git",
    "directory": "packages/alife-mapgen"
  },
  "homepage": "https://github.com/eurusik/alife-sdk#readme",
  "bugs": {
    "url": "https://github.com/eurusik/alife-sdk/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
