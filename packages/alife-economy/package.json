{
  "name": "@alife-sdk/economy",
  "version": "0.1.0",
  "description": "Trade, inventory, and quest systems for A-Life SDK",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./inventory": {
      "types": "./dist/inventory/index.d.ts",
      "import": "./dist/inventory/index.js"
    },
    "./trade": {
      "types": "./dist/trade/index.d.ts",
      "import": "./dist/trade/index.js"
    },
    "./quest": {
      "types": "./dist/quest/index.d.ts",
      "import": "./dist/quest/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "import": "./dist/ports/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "alife",
    "game-ai",
    "economy",
    "trade",
    "inventory",
    "quest"
  ],
  "license": "MIT",
  "author": "Eugene Rusakov",
  "repository": {
    "type": "git",
    "url": "https://github.com/eurusik/alife-sdk.git",
    "directory": "packages/alife-economy"
  },
  "homepage": "https://github.com/eurusik/alife-sdk#readme",
  "bugs": {
    "url": "https://github.com/eurusik/alife-sdk/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@alife-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
