{
  "name": "@alife-sdk/social",
  "version": "0.4.1",
  "description": "NPC social interaction systems — greetings, remarks, campfire storytelling",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./meet": {
      "types": "./dist/meet/index.d.ts",
      "import": "./dist/meet/index.js"
    },
    "./remark": {
      "types": "./dist/remark/index.d.ts",
      "import": "./dist/remark/index.js"
    },
    "./campfire": {
      "types": "./dist/campfire/index.d.ts",
      "import": "./dist/campfire/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "import": "./dist/ports/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "alife",
    "game-ai",
    "social",
    "npc",
    "campfire",
    "dialogue"
  ],
  "license": "MIT",
  "author": "Eugene Rusakov",
  "repository": {
    "type": "git",
    "url": "https://github.com/eurusik/alife-sdk.git",
    "directory": "packages/alife-social"
  },
  "homepage": "https://github.com/eurusik/alife-sdk#readme",
  "bugs": {
    "url": "https://github.com/eurusik/alife-sdk/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@alife-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
